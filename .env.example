# API
NODE_ENV=development
PORT=4000
GUEST_DEFAULT_PLAN=free
# Use 0.0.0.0 for real iPhone testing on the same Wi-Fi.
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/melody_ai
# Local no-Docker fallback:
# DATABASE_URL=pglite://./.pglite
APP_PUBLIC_URL=http://localhost:4000
ADMIN_API_KEY=change-me-admin-key

# MiniMax Music API
MINIMAX_API_KEY=change-me
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_MUSIC_MODEL=music-2.6
MINIMAX_IMAGE_MODEL=image-01
MINIMAX_COST_CENTS_PER_SONG=8
MINIMAX_IMAGE_COST_CENTS_PER_COVER=2
MINIMAX_REQUEST_TIMEOUT_MS=300000

# S3 / Cloudflare R2
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=melody-ai-generated
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_PUBLIC_BASE_URL=https://cdn.example.com

# Apple App Store Server API / StoreKit 2
APPLE_BUNDLE_ID=com.melodyai.mobile
APPLE_APP_APPLE_ID=1234567890
APPLE_ISSUER_ID=00000000-0000-0000-0000-000000000000
APPLE_KEY_ID=ABC123DEFG
APPLE_PRIVATE_KEY_PATH=/secure/AuthKey_ABC123DEFG.p8
APPLE_ENVIRONMENT=Sandbox
APPLE_ROOT_CERT_PATHS=/secure/AppleRootCA-G3.cer,/secure/AppleRootCA-G2.cer
APPLE_ENABLE_ONLINE_CHECKS=true

# Mobile app
# Simulator can use localhost. Real iPhone must use your Mac LAN IP, for example:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.31.207:4000/api
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:4000/api
EXPO_PUBLIC_DEMO_USER_ID=11111111-1111-4111-8111-111111111111

# Admin app
VITE_API_BASE_URL=http://localhost:4000/api
VITE_ADMIN_API_KEY=change-me-admin-key
